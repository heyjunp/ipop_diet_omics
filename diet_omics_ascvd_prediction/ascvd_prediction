library(glmnet); library(dplyr); library(caret)
library(missForest); library(ranger)
library(ggplot2); library(gridExtra)
library(pdp); library(iml)

data_dir <- "../data"
fig_dir  <- "Figures"
if (!dir.exists(fig_dir)) dir.create(fig_dir)

ascvd <- read.csv(file.path(data_dir, "ascvd_merged_data_cleaned.csv"),
                  header = TRUE, quote = "\"", skipNul = TRUE,
                  na.strings = c(NA, " "))

### violin plot
ascvd$aha10risk_pct <- ascvd$aha10risk * 100
ascvd_overall <- subset(ascvd, !is.na(aha10risk_pct))

beige <- "#993300"
p_violin <- ggplot(ascvd_overall, aes(y = "", x = aha10risk_pct)) +
